{
  "name": "outlit-pi-agents-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Example Pi agents built with Outlit customer intelligence tools",
  "keywords": [
    "outlit",
    "pi-package",
    "customer-intelligence",
    "churn",
    "activation",
    "expansion"
  ],
  "pi": {
    "extensions": [
      "./extensions/outlit-growth-agents.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/@outlit/pi/skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@outlit/pi": "canary",
    "@outlit/tools": "canary"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.1",
    "@sinclair/typebox": "^0.34.41",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
